# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── Database (MySQL) ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=craftworldcentre
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_CONNECTION_LIMIT=10

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_very_long_access_secret_at_least_64_chars
JWT_REFRESH_SECRET=your_very_long_refresh_secret_at_least_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Bcrypt ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=craftworldcentre

# ── Paystack ─────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here
PAYSTACK_BASE_URL=https://api.paystack.co

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=CraftworldCentre <no-reply@craftworldcentre.com>
EMAIL_SUPPORT=hello@craftworldcentre.com

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://craftworldcentre.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ── Cookie ────────────────────────────────────────────────────
COOKIE_SECRET=your_cookie_secret_here

# ── OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ── URLs ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@craftworldcentre.com
ADMIN_PASSWORD=AdminSecureP@ss123
